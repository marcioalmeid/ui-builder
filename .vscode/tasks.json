{
  // For more information, visit: https://go.microsoft.com/fwlink/?LinkId=733558
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "start",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Changes detected"
          },
          "endsPattern": {
            "regexp": "bundle generation (complete|failed)"
          }
        }
      }
    },
    {
      "type": "npm",
      "script": "test",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Changes detected"
          },
          "endsPattern": {
            "regexp": "bundle generation (complete|failed)"
          }
        }
      }
    },
     {
      "label": "Claude: Gerar Mensagem de Commit",
      "type": "shell",
      // O comando agora lê o diff do git e passa para o claude como texto puro
      "command": "git diff --cached | claude \"$(git diff --cached) generate a single line commit message. Output ONLY the text.\" | pbcopy",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    }
  ]
}
